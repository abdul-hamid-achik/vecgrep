# vecgrep environment configuration
# Copy this file to .env and customize as needed

# Embedding provider: ollama, openai
VECGREP_EMBEDDING_PROVIDER=ollama

# Embedding model name
VECGREP_EMBEDDING_MODEL=nomic-embed-text

# Ollama API URL (for ollama provider)
VECGREP_OLLAMA_URL=http://localhost:11434

# OpenAI API key (for openai provider)
# VECGREP_OPENAI_API_KEY=sk-...

# OpenAI base URL (for custom endpoints like Azure OpenAI)
# VECGREP_OPENAI_BASE_URL=https://api.openai.com/v1
